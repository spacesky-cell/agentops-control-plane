{
  "name": "scripted-ci-fix-agent",
  "steps": [
    {
      "tool": "list_files",
      "args": {"pattern": "**/*.py"}
    },
    {
      "tool": "read_file",
      "args": {"path": "math_utils.py"}
    },
    {
      "tool": "patch_text",
      "args": {
        "path": "math_utils.py",
        "old": "return a - b",
        "new": "return a + b"
      }
    },
    {
      "tool": "run_command",
      "args": {"command": "python -m unittest -q"}
    }
  ]
}

