{
  "name": "mcp-local-ci-fix-adapter",
  "tool_calls": [
    {
      "name": "list_files",
      "arguments": {"pattern": "**/*.py"}
    },
    {
      "name": "read_file",
      "arguments": {"path": "math_utils.py"}
    },
    {
      "name": "patch_text",
      "arguments": {
        "path": "math_utils.py",
        "old": "return a - b",
        "new": "return a + b"
      }
    },
    {
      "name": "run_command",
      "arguments": {"command": "python -m unittest -q"}
    }
  ]
}
