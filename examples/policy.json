{
  "command_allow_prefixes": [
    ["python", "-m", "unittest"],
    ["python", "-m", "pytest"],
    ["pytest"],
    ["git", "diff"],
    ["git", "status"],
    ["npm", "test"],
    ["pnpm", "test"],
    ["pnpm", "run", "test"]
  ],
  "command_deny_prefixes": [
    ["rm", "-rf"],
    ["Remove-Item"],
    ["del"],
    ["format"],
    ["shutdown"],
    ["git", "push"],
    ["git", "reset", "--hard"],
    ["curl"],
    ["wget"],
    ["Invoke-WebRequest"]
  ],
  "protected_globs": [
    ".env",
    ".env.*",
    "**/.env",
    "**/.env.*",
    "**/*secret*",
    "**/*token*",
    "**/id_rsa",
    ".git/**"
  ],
  "write_requires_approval": true,
  "patch_requires_approval": true,
  "unknown_command_requires_approval": true,
  "max_command_seconds": 30,
  "max_output_chars": 8000,
  "max_mcp_frame_bytes": 1048576,
  "max_tool_argument_bytes": 262144,
  "max_file_bytes": 1048576,
  "max_source_bytes": 16777216
}

